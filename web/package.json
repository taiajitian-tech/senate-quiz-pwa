{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "gen:senators": "node scripts/fetchSenators.mjs",
    "typecheck": "tsc --noEmit",
    "check:data": "node scripts/validateSenators.mjs && node scripts/validateMinisters.mjs",
    "check": "npm run typecheck && npm run build && npm run check:data",
    "prepare": "node scripts/setupHooks.mjs",
    "gen:ministers": "node scripts/fetchMinisters.mjs",
    "gen:representatives": "node scripts/fetchRepresentatives.mjs",
    "check:representatives": "node scripts/validateRepresentatives.mjs",
    "gen:representatives:images": "node scripts/autoImageFetch.mjs",
    "report:representatives:images": "node scripts/imageReport.mjs",
    "nhk:card": "node scripts/fetchNhkByCard.mjs"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "cheerio": "^1.0.0-rc.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "prettier": "^3.6.2"
  }
}
